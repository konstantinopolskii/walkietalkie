{
  "manifest_version": 3,
  "name": "TalkTrack",
  "version": "0.1.0",
  "description": "Talk and tap. TalkTrack records voice plus DOM interactions on any page and ships an audio + log bundle to disk.",
  "permissions": [
    "downloads",
    "offscreen",
    "scripting",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TalkTrack"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
